// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  colorPanels        ColorPanel[] // custom panels
  email              String       @unique
  hashedRefreshToken String?
  id                 String       @id @default(uuid())
  password           String
  role               String
  vocabulary         Vocabulary[]
  workspaces         Workspace[] // owns
}

model Workspace {
  colorPanel     ColorPanel?   @relation(fields: [colorPanelId], references: [id])
  colorPanelId   String?
  id             String        @id @default(uuid())
  languages      Json
  name           String
  nativeLanguage String
  preparations   Preparation[]
  userId         String
  user           User          @relation(fields: [userId], references: [id])
  vocabulary     Vocabulary[]
}

model ColorPanel {
  colors     ColorSwatch[]
  id         String        @id @default(uuid())
  name       String
  userId     String
  user       User          @relation(fields: [userId], references: [id])
  workspaces Workspace[]
}

model ColorSwatch {
  id      String     @id @default(uuid())
  name    String
  value   String
  panelId String
  panel   ColorPanel @relation(fields: [panelId], references: [id])

  // <<< back-relations vers les entités qui référencent ce swatch >>>
  notes               Note[]          @relation("NoteColor")
  pdfElementsAsFill   PdfElement[]    @relation("PdfElementFillColor")
  pdfElementsAsStroke PdfElement[]    @relation("PdfElementStrokeColor")
  pdfVocabulary       PdfVocabulary[] @relation("PdfVocabularyColor")

  @@unique([panelId, name]) // Unique names in a same panel
}

model Preparation {
  folders     Folder[]
  id          String       @id @default(uuid())
  title       String
  vocabulary  Vocabulary[]
  workspace   Workspace    @relation(fields: [workspaceId], references: [id])
  workspaceId String
}

model Folder {
  files          File[]
  id             String      @id @default(uuid())
  name           String
  parentFolder   Folder?     @relation("FolderHierarchy", fields: [parentFolderId], references: [id])
  parentFolderId String? // for recursive folders
  preparation    Preparation @relation(fields: [preparationId], references: [id])
  preparationId  String
  subFolders     Folder[]    @relation("FolderHierarchy")
}

model File {
  id                 String          @id @default(uuid())
  folderId           String
  folder             Folder          @relation(fields: [folderId], references: [id])
  name               String
  path               String
  // Unifie les notes : toutes les notes (libres ou ancrées)
  notes              Note[]
  // Les éléments de dessin PDF (rect/path/text) pour le rendu
  pdfElements        PdfElement[]
  // Occurrences "sur le PDF" d’un terme (peuvent mapper à un Vocabulary global)
  pdfVocabulary      PdfVocabulary[]
  // Surbrillances cliquables qui référencent soit une Note soit un Vocabulary
  references         Reference[]
  vocabularyAsSource Vocabulary[]    @relation("FileAsSource")

  @@unique([folderId, name])
}

model Note {
  id     String @id @default(uuid())
  fileId String
  file   File   @relation(fields: [fileId], references: [id])

  content   String
  pageIndex Int

  occurence Json?
  x         Int?
  y         Int?
  width     Int?
  height    Int?

  colorMode ColorSource  @default(PANEL)
  colorId   String?
  color     ColorSwatch? @relation("NoteColor", fields: [colorId], references: [id])

  reference Reference[]
}

model Reference {
  id     String @id @default(uuid())
  fileId String
  file   File   @relation(fields: [fileId], references: [id])

  type         ReferenceType // NOTE | VOCABULARY
  noteId       String?
  note         Note?         @relation(fields: [noteId], references: [id])
  vocabularyId String?
  vocabulary   Vocabulary?   @relation(fields: [vocabularyId], references: [id])

  // Géométrie de la zone cliquable (ou de l’annotation)
  pageIndex Int
  x         Int
  y         Int
  width     Int
  height    Int
}

model PdfElement {
  id        String      @id @default(uuid())
  fileId    String
  file      File        @relation(fields: [fileId], references: [id])
  pageIndex Int
  type      DrawingType

  // --- Common fields ---
  x Float?
  y Float?

  // Z-order si tu veux contrôler le rendu (optionnel)
  zIndex Int? @default(0)

  // --- Spécifique RECTANGLE ---
  width   Float? // RECTANGLE uniquement
  height  Float? // RECTANGLE uniquement
  // Opacité utilisée pour RECTANGLE & PATH (TEXT n'en a pas côté front, donc nullable)
  opacity Float?

  // --- Spécifique PATH ---
  path        String? // PATH uniquement (d string)
  borderWidth Float? // PATH uniquement

  // --- Spécifique TEXT ---
  text     String? // TEXT uniquement
  fontSize Float? // TEXT uniquement (TextOptions.size)

  // --- Couleurs ---
  fillColorMode ColorSource? @default(PANEL)
  fillColorId   String?
  fillColor     ColorSwatch? @relation("PdfElementFillColor", fields: [fillColorId], references: [id])

  strokeColorMode ColorSource? @default(PANEL)
  strokeColorId   String?
  strokeColor     ColorSwatch? @relation("PdfElementStrokeColor", fields: [strokeColorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([fileId, pageIndex, type], name: "idx_pdf_element_page_type")
}

model PdfVocabulary {
  id     String @id @default(uuid())
  fileId String
  file   File   @relation(fields: [fileId], references: [id])

  occurence    Json
  translations Json

  colorMode ColorSource  @default(PANEL)
  colorId   String?
  color     ColorSwatch? @relation("PdfVocabularyColor", fields: [colorId], references: [id])

  vocabularyId String?
  vocabulary   Vocabulary? @relation(fields: [vocabularyId], references: [id])
}

model Vocabulary {
  id           String    @id @default(uuid())
  term         String // <--- ajouté, ex: "accusamus"
  translations Json
  userId       String
  user         User      @relation(fields: [userId], references: [id])
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id])

  // optionnel : rattacher à une préparation si tu veux “geler” un snapshot
  preparationId String?
  preparation   Preparation? @relation(fields: [preparationId], references: [id])

  // Occurrences sur pdf, et références possibles
  pdfVocabulary PdfVocabulary[]
  reference     Reference[]

  sourceFileId String?
  sourceFile   File?   @relation("FileAsSource", fields: [sourceFileId], references: [id])

  @@unique([workspaceId, term]) // utile pour upsert propre
}

enum ColorSource {
  INLINE // hard coded
  PANEL // reference to a color variable
}

enum DrawingType {
  PATH
  RECTANGLE
  TEXT
}

enum ReferenceType {
  NOTE
  VOCABULARY
}
