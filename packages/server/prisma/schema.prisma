// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/////////////////////
// Modèles "métier"
/////////////////////

model User {
  colorPanels        ColorPanel[] // custom panels
  email              String       @unique
  hashedRefreshToken String?
  id                 String       @id @default(uuid())
  password           String
  role               String
  workspaces         Workspace[] // owns
}

model Workspace {
  colorPanel      ColorPanel?               @relation(fields: [colorPanelId], references: [id])
  colorPanelId    String?
  id              String                    @id @default(uuid())
  languages       Json
  name            String
  nativeLanguage  String
  preparations    Preparation[]
  userId          String
  user            User                      @relation(fields: [userId], references: [id])
  vocabularyTerms WorkspaceVocabularyTerm[]
}

model ColorPanel {
  colors     ColorSwatch[]
  id         String        @id @default(uuid())
  name       String
  userId     String
  user       User          @relation(fields: [userId], references: [id])
  workspaces Workspace[]
}

model ColorSwatch {
  id      String     @id @default(uuid())
  name    String
  value   String
  panelId String
  panel   ColorPanel @relation(fields: [panelId], references: [id])

  @@unique([panelId, name]) // Unique names in a same panel
}

model Preparation {
  id      String   @id @default(cuid())
  title   String
  pdfFiles PdfFile[] @relation("PreparationFiles")

  vocabularyTerms PreparationVocabularyTerm[]

  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  workspaceId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PdfFile {
  id       String @id @default(cuid())
  name     String
  s3Key    String
  filePath  String
  actions  String

  preparationId String
  preparation   Preparation @relation("PreparationFiles", fields: [preparationId], references: [id])

  vocabularyOccurrences VocabularyOccurrence[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([preparationId])
  @@index([name])
}

/////////////////////
// Vocabulaire
/////////////////////

model VocabularyTerm {
  id           String   @id @default(cuid())
  colorJson    Json
  translations String[] @default([])

  preparations PreparationVocabularyTerm[]
  workspaces   WorkspaceVocabularyTerm[]
  occurrences  VocabularyOccurrence[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PreparationVocabularyTerm {
  // Table de jointure M-N entre Preparation et VocabularyTerm
  preparationId String
  termId        String

  preparation Preparation    @relation(fields: [preparationId], references: [id])
  term        VocabularyTerm @relation(fields: [termId], references: [id])

  // Optionnel : métadonnées par préparation (ex: statut, tags…)
  // metaJson     Json?

  @@id([preparationId, termId])
  @@index([termId])
}

model WorkspaceVocabularyTerm {
  workspaceId String
  termId      String

  workspace Workspace      @relation(fields: [workspaceId], references: [id])
  term      VocabularyTerm @relation(fields: [termId], references: [id])

  // Optionnel: méta par workspace (tags, statut, difficulté, etc.)
  // metaJson   Json?

  @@id([workspaceId, termId]) // un terme unique par workspace
  @@index([termId])
  @@index([workspaceId])
}

model VocabularyOccurrence {
  id     String         @id @default(cuid())
  termId String
  term   VocabularyTerm @relation(fields: [termId], references: [id])

  // Où : fichier + page
  pdfFileId String
  pdfFile   PdfFile @relation(fields: [pdfFileId], references: [id])
  pageIndex Int

  // Le texte exact sur lequel porte l’occurrence
  text String

  // Si tu veux garder une redondance du filePath du front (peut servir pour dénormaliser)
  filePath String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([pdfFileId, pageIndex, termId])
  @@index([termId])
  @@index([pdfFileId, pageIndex])
}
