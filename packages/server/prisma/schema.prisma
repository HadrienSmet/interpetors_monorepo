// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  colorPanels        ColorPanel[] // custom panels
  email              String       @unique
  hashedRefreshToken String?
  id                 String       @id @default(uuid())
  password           String
  role               String
  vocabulary         Vocabulary[]
  workspaces         Workspace[] // owns
}

model Workspace {
  colorPanel     ColorPanel?   @relation(fields: [colorPanelId], references: [id])
  colorPanelId   String?
  id             String        @id @default(uuid())
  languages      Json
  name           String
  nativeLanguage String
  preparations   Preparation[]
  userId         String
  user           User          @relation(fields: [userId], references: [id])
  vocabulary     Vocabulary[]
}

model ColorPanel {
  colors     Json // Record<label, color>
  id         String      @id @default(uuid())
  name       String
  user       User        @relation(fields: [userId], references: [id])
  userId     String
  workspaces Workspace[]
}

model Preparation {
  folders     Folder[]
  id          String       @id @default(uuid())
  title       String
  vocabulary  Vocabulary[]
  workspace   Workspace    @relation(fields: [workspaceId], references: [id])
  workspaceId String
}

model Folder {
  files          File[]
  id             String      @id @default(uuid())
  name           String
  parentFolder   Folder?     @relation("FolderHierarchy", fields: [parentFolderId], references: [id])
  parentFolderId String? // for recursive folders
  preparation    Preparation @relation(fields: [preparationId], references: [id])
  preparationId  String
  subFolders     Folder[]    @relation("FolderHierarchy")
}

model File {
  id                 String       @id @default(uuid())
  folderId           String
  folder             Folder       @relation(fields: [folderId], references: [id])
  name               String
  path               String
  // Unifie les notes : toutes les notes (libres ou ancrées)
  notes              Note[]
  // Les éléments de dessin PDF (rect/path/text) pour le rendu
  pdfElements        PdfElement[]
  // Occurrences "sur le PDF" d’un terme (peuvent mapper à un Vocabulary global)
  pdfVocabulary      PdfVocabulary[]
  // Surbrillances cliquables qui référencent soit une Note soit un Vocabulary
  references         Reference[]
  vocabularyAsSource Vocabulary[] @relation("FileAsSource")

  @@unique([folderId, name])
}

model Note {
  id        String  @id @default(uuid())
  fileId    String
  file      File    @relation(fields: [fileId], references: [id])

  // Notes libres
  content   String
  pageIndex Int

  // Pour notes "ancrées"
  color     String?
  occurence Json?   // TextOccurrence (payload)
  x         Int?    // pos facultative si tu veux les afficher
  y         Int?
  width     Int?
  height    Int?

  reference Reference[] // plusieurs références (zones cliquables) peuvent pointer la même note
}

model Reference {
  id           String         @id @default(uuid())
  fileId       String
  file         File           @relation(fields: [fileId], references: [id])

  type         ReferenceType  // NOTE | VOCABULARY
  noteId       String?
  note         Note?          @relation(fields: [noteId], references: [id])
  vocabularyId String?
  vocabulary   Vocabulary?    @relation(fields: [vocabularyId], references: [id])

  // Géométrie de la zone cliquable (ou de l’annotation)
  pageIndex Int
  x         Int
  y         Int
  width     Int
  height    Int
}

model PdfVocabulary {
  id           String      @id @default(uuid())
  fileId       String
  file         File        @relation(fields: [fileId], references: [id])
  color        String
  occurence    Json
  translations Json
  vocabularyId String?     // <-- plus de @unique ici !
  vocabulary   Vocabulary? @relation(fields: [vocabularyId], references: [id])
}

model Vocabulary {
  id            String       @id @default(uuid())
  term          String       // <--- ajouté, ex: "accusamus"
  translations  Json
  userId        String
  user          User         @relation(fields: [userId], references: [id])
  workspaceId   String
  workspace     Workspace    @relation(fields: [workspaceId], references: [id])

  // optionnel : rattacher à une préparation si tu veux “geler” un snapshot
  preparationId String?
  preparation   Preparation? @relation(fields: [preparationId], references: [id])

  // Occurrences sur pdf, et références possibles
  pdfVocabulary PdfVocabulary[]
  reference     Reference[]

  sourceFileId  String?
  sourceFile    File?        @relation("FileAsSource", fields: [sourceFileId], references: [id])

  @@unique([workspaceId, term]) // utile pour upsert propre
}

enum DrawingType {
  PATH
  RECTANGLE
  TEXT
}

enum ReferenceType {
  NOTE
  VOCABULARY
}
