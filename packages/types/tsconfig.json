{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"composite": true,
		"rootDir": "src",
		"outDir": "dist",
		"declaration": true,
		"declarationMap": true,
		"emitDeclarationOnly": false,
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"noEmit": false,
		"target": "ES2020",
		"skipLibCheck": true
	},
	"include": ["src"]
}
